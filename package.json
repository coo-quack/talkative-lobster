{
  "name": "talkative-lobster",
  "version": "1.2.5",
  "description": "Talk to your AI — literally. A desktop voice conversation app.",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "coo-quack",
  "homepage": "https://coo-quack.github.io/talkative-lobster/",
  "scripts": {
    "format": "biome format --write",
    "format:check": "biome format",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@elevenlabs/elevenlabs-js": "^2.39.0",
    "@ricky0123/vad-react": "^0.0.36",
    "@ricky0123/vad-web": "^0.0.30",
    "@tailwindcss/vite": "^4.2.1",
    "@xstate/react": "^6.1.0",
    "lucide-react": "^1.0.0",
    "onnxruntime-web": "^1.24.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "ws": "^8.19.0",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.0",
    "msw": "^2.12.10",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-static-copy": "^3.3.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "minimatch@<3.1.4": "10.2.5",
      "minimatch@>=9 <9.0.7": "10.2.5",
      "minimatch@>=10 <10.2.3": "10.2.5",
      "tar@<7.5.11": "7.5.13",
      "esbuild@<0.25.0": "0.28.0",
      "undici@>=7.0.0 <7.24.0": "8.0.3",
      "yauzl@<3.2.1": "3.3.0"
    }
  }
}
